# =============================================================================
# AI Live Demo Backend - env template
# Copy this file to `backend/.env` and fill in real values.
# =============================================================================

# --- Anthropic API keys -------------------------------------------------------
# 開発用キー (個人 Workspace 推奨)
ANTHROPIC_API_KEY=your-dev-key-here

# 公開デモ用キー (Anthropic Console > Workspace "ai-live-demo-public" の専用キー)
# 設定されている場合は ANTHROPIC_API_KEY より優先される。
# 本番デプロイ時のみセットすること (開発時は空でよい)。
ANTHROPIC_API_KEY_PROD=

# --- Runtime flags ------------------------------------------------------------
# 1 にすると /test-llm エンドポイントが有効になる。本番では未設定にすること。
DEBUG=0

# 許可するフロントエンドの origin (カンマ区切り)。
# 開発時は localhost、本番ではデプロイ先ドメインだけを書く。
CORS_ORIGINS=http://localhost:8000,http://localhost:5500,http://localhost:8001

# --- Daily budget guards ------------------------------------------------------
# 1日あたりの合計トークン上限。超過時は全リクエストを 503 で拒否。
DAILY_TOKEN_BUDGET=500000
# 1日あたりの合計リクエスト数上限 (slowapi の IP 単位制限に加えて適用)。
DAILY_REQUEST_BUDGET=1000

# --- TODO: 未実装 (将来パスワードゲート導入時にここへ) ----------------------
# DEMO_PASSWORD=
# DASHBOARD_PASSWORD=
